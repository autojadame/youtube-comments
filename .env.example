# ----------------------------
# Core
# ----------------------------
APP_NAME="SafeBlockLab Social Bot"
PORT=3000
BASE_URL="http://localhost:3000"
SESSION_SECRET="change-me"
DB_FILE="./data.sqlite"

# Optional: internal API key (used by /api/* endpoints)
INTERNAL_API_KEY="change-me"

# ----------------------------
# DeepSeek
# ----------------------------
DEEPSEEK_API_KEY="..."
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_MAX_TOKENS=300
DEEPSEEK_TEMPERATURE=0.7

# ----------------------------
# YouTube OAuth (Google Cloud Console)
# ----------------------------
YOUTUBE_CLIENT_ID="..."
YOUTUBE_CLIENT_SECRET="..."
YOUTUBE_REDIRECT_URI="http://localhost:3000/youtube/callback"
# Minimal scope for replying to comments
YOUTUBE_SCOPES="https://www.googleapis.com/auth/youtube.force-ssl"

# ----------------------------
# Meta OAuth (Facebook App)
# ----------------------------
META_GRAPH_VERSION="v25.0"
META_APP_ID="..."
META_APP_SECRET="..."
META_REDIRECT_URI="http://localhost:3000/meta/callback"
META_LOGIN_CONFIG_ID=""  # optional
META_SCOPES="pages_manage_posts,pages_read_engagement,pages_manage_metadata,pages_manage_engagement,instagram_manage_comments"

# ----------------------------
# Worker
# ----------------------------
YT_CRON="*/2 * * * *"     # every 2 minutes
META_CRON="*/5 * * * *"   # every 5 minutes
MAX_REPLIES_PER_RUN=30
REPLY_COOLDOWN_SECONDS=2
