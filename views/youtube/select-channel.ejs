<!-- views/youtube/select-channel.ejs -->
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= "YouTube — Connect Channel — " + appName %></title>

  <meta name="description" content="Authorize a YouTube channel for comment auto-replies." />
  <meta name="robots" content="noindex,nofollow" />

  <link rel="preconnect" href="https://rsms.me">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="/public/css/app.css" />
  <link rel="icon" href="/public/assets/logo.svg" />

  <link rel="stylesheet" href="/public/css/select-assets.css" />
</head>

<body>
  <div class="app-shell">
    <%- include('../_partials/nav.ejs') %>

    <main class="container">
      <%- include('../_partials/flash.ejs') %>

      <section class="grid">
        <div class="card">
          <div class="pill">YouTube OAuth</div>
          <h1 class="h1" style="font-size:30px;">Select channel & bot settings</h1>

          <p class="lead">
            Choose which channel will authorize the bot. The worker will reply to new comments using DeepSeek.
          </p>

          <div class="hr"></div>

          <% if (!channels || channels.length === 0) { %>
            <div class="flash warn">
              <div class="flash-dot"></div>
              <div class="flash-msg">
                No channels returned for this Google account. Make sure the user has a YouTube channel.
              </div>
            </div>

            <div class="btn-row" style="margin-top:14px;">
              <a class="btn primary" href="/">Back</a>
              <a class="btn" href="/youtube/connect">Reconnect</a>
            </div>

          <% } else { %>

            <form class="form" method="post" action="/youtube/confirm">
              <div>
                <div class="label">Organization name (optional)</div>
                <input class="input" type="text" name="org_name" value="<%= orgName || '' %>" placeholder="e.g., Luxverbi" />
                <div class="mini">Only for display / multi-tenant grouping. Not required for YouTube API calls.</div>
              </div>

              <div>
                <div class="label"><span class="req">Channel key</span></div>
                <input class="input" type="text" name="channel_key" value="<%= channelKey || '' %>" placeholder="e.g., luxverbi_youtube" required />
                <div class="mini">Stable key your worker uses to identify this connection.</div>
              </div>

              <div>
                <div class="label"><span class="req">YouTube channel</span></div>
                <select name="yt_channel_id" required>
                  <% channels.forEach(function(ch){ %>
                    <option value="<%= ch.id %>" <%= (selectedChannelId && selectedChannelId === ch.id) ? 'selected' : '' %>>
                      <%= ch.title %> — <%= ch.id %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <div class="two-col">
                <div class="lang-card">
                  <div class="lang-head">
                    <div class="row">
                      <span class="tag">Auto-reply</span>
                      <span class="pill">DeepSeek</span>
                    </div>
                    <label class="ck">
                      <input type="checkbox" name="auto_reply" value="1" <%= (autoReply === false) ? '' : 'checked' %> />
                      <span>Enabled</span>
                    </label>
                  </div>
                  <div class="mini" style="margin-top:10px;">
                    Replies are generated and posted as your channel. Anti-spam safeguards apply (rate limit, one reply per comment).
                  </div>
                </div>

                <div class="lang-card">
                  <div class="lang-head">
                    <div class="row">
                      <span class="tag">Heart comments</span>
                      <span class="pill">Not supported</span>
                    </div>
                    <label class="ck" title="No official YouTube Data API endpoint exists for hearts">
                      <input type="checkbox" name="auto_heart" value="1" disabled />
                      <span>Enabled</span>
                    </label>
                  </div>
                  <div class="mini" style="margin-top:10px;">
                    The YouTube Data API supports replying (comments.insert), but does not expose a "heart" action for comments.
                  </div>
                </div>
              </div>

              <div class="hr"></div>

              <div class="btn-row">
                <button class="btn primary" type="submit">Save connection</button>
                <a class="btn" href="/">Cancel</a>
              </div>
            </form>

          <% } %>
        </div>

        <aside>
          <div class="card">
            <div class="card-title">What gets stored</div>
            <p class="small" style="margin-top:6px;">
              We store refresh tokens server-side to auto-renew access. We also store comment IDs we already replied to.
            </p>
            <ul class="ul">
              <li>channel_key + yt_channel_id</li>
              <li>refresh_token (offline access)</li>
              <li>access_token + expiry (cached)</li>
              <li>last scan cursor (publishedAt)</li>
              <li>comment IDs replied (idempotency)</li>
            </ul>
          </div>

          <div class="card">
            <div class="card-title">Good practice</div>
            <p class="small" style="margin-top:6px;">
              Avoid replying to spam, and keep replies concise. If you want, we can add a "manual review" queue.
            </p>
          </div>
        </aside>
      </section>
    </main>

    <%- include('../_partials/footer.ejs') %>
  </div>
</body>
</html>
