<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title ? `${title} — ${appName}` : appName %></title>
  <link rel="preconnect" href="https://rsms.me">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="/public/css/app.css" />
  <link rel="icon" href="/public/assets/logo.svg" />
</head>
<body>
  <div class="app-shell">
    <%- include('./_partials/nav.ejs') %>
    <main class="container">
      <%- include('./_partials/flash.ejs') %>

      <div class="card">
        <h1 class="h1" style="font-size:32px;">Data Deletion</h1>
        <p class="lead">Request removal of stored Meta connection data.</p>

        <p class="small">
          To request deletion, email <b>support@safeblocklab.com</b> with:
        </p>
        <ul class="ul">
          <li>Your organization identifier (org_id)</li>
          <li>Language scope (en / es)</li>
          <li>The Page ID you connected (if known)</li>
        </ul>

        <div class="hr"></div>

        <p class="small">
          If your request is verified, we will remove stored tokens and asset mappings associated with your org_id.
        </p>
      </div>
    </main>
    <%- include('./_partials/footer.ejs') %>
  </div>
</body>
</html>
