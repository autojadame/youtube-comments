<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title ? `${title} — ${appName}` : appName %></title>
  <link rel="preconnect" href="https://rsms.me">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="/public/css/app.css" />
  <link rel="icon" href="/public/assets/logo.svg" />
</head>
<body>
  <div class="app-shell">
    <%- include('./_partials/nav.ejs') %>
    <main class="container">
      <%- include('./_partials/flash.ejs') %>

      <div class="card">
        <h1 class="h1" style="font-size:32px;">Contact</h1>
        <p class="lead">Support and compliance contact for this integration.</p>

        <div class="card-title">Email</div>
        <p class="small">support@safeblocklab.com</p>

        <div class="card-title" style="margin-top:14px;">Notes</div>
        <p class="small">
          If you are requesting data deletion, please include your organization identifier (org_id) and the language scope (en/es).
        </p>
      </div>
    </main>
    <%- include('./_partials/footer.ejs') %>
  </div>
</body>
</html>
