<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title ? `${title} — ${appName}` : appName %></title>
  <link rel="preconnect" href="https://rsms.me">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="/public/css/app.css" />
  <link rel="icon" href="/public/assets/logo.svg" />
</head>
<body>
  <div class="app-shell">
    <%- include('./_partials/nav.ejs') %>
    <main class="container">
      <%- include('./_partials/flash.ejs') %>

      <div class="card">
        <h1 class="h1" style="font-size:32px;">Privacy Policy</h1>
        <p class="lead">Last updated: <%= new Date().toISOString().slice(0,10) %></p>

        <p class="small">
          This service provides Meta OAuth onboarding for business assets and enables publishing workflows for authorized users.
          We process the minimum data required to connect and operate on selected assets.
        </p>

        <div class="hr"></div>

        <div class="card-title">Data we process</div>
        <ul class="ul">
          <li>OAuth identifiers (Meta user id) to link the authorization session.</li>
          <li>Business asset identifiers selected by the user (Page ID, optional IG business account ID).</li>
          <li>Access tokens required to act on selected assets (stored server-side).</li>
        </ul>

        <div class="card-title" style="margin-top:14px;">Contact</div>
        <p class="small">
          For privacy requests, contact us via <a href="/contact">/contact</a>.
        </p>
      </div>
    </main>
    <%- include('./_partials/footer.ejs') %>
  </div>
</body>
</html>
