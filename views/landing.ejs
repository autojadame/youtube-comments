<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= title ? (title + " — " + appName) : appName %></title>

  <meta name="description" content="Connect YouTube + Meta and auto-reply to comments securely." />
  <meta name="robots" content="index,follow" />

  <link rel="preconnect" href="https://rsms.me">
  <link rel="stylesheet" href="https://rsms.me/inter/inter.css">
  <link rel="stylesheet" href="/public/css/app.css" />
  <link rel="icon" href="/public/assets/logo.svg" />
</head>
<body>
  <div class="app-shell">
    <%- include('./_partials/nav.ejs') %>

    <main class="container">
      <%- include('./_partials/flash.ejs') %>

      <section class="grid">
        <div class="card">
          <div class="pill">YouTube</div>
          <h1 class="h1">Auto-reply to YouTube comments with DeepSeek</h1>
          <p class="lead">
            Users connect their YouTube channel via OAuth. The worker polls for new comments,
            generates replies with DeepSeek, and posts them as your channel.
          </p>

          <div class="hr"></div>

          <div class="card-title">Status</div>
          <% if (yt && yt.connected) { %>
            <p class="small" style="margin-top:8px;">
              Connected channel: <b><%= yt.channel_title || yt.channel_id %></b><br/>
              Channel key: <b><%= yt.channel_key %></b>
            </p>
            <div class="btn-row" style="margin-top:12px;">
              <a class="btn primary" href="/youtube/select-channel">Manage</a>
              <form method="post" action="/youtube/logout" style="display:inline;">
                <button class="btn" type="submit">Disconnect</button>
              </form>
            </div>
            <div class="hr"></div>
            <div class="card-title">Note</div>
            <p class="small" style="margin-top:6px;">
              YouTube Data API supports replying to comments via <code>comments.insert</code>,
              but it does <b>not</b> provide an official endpoint to "heart" comments.
            </p>
          <% } else { %>
            <p class="small" style="margin-top:8px;">
              Not connected. Start OAuth and authorize comment management for your channel.
            </p>
            <div class="btn-row" style="margin-top:12px;">
              <a class="btn primary" href="/youtube/connect">Connect YouTube</a>
            </div>
          <% } %>
        </div>

        <aside>
          <div class="card">
            <div class="pill">Meta</div>
            <h2 style="margin:10px 0 8px; font-size:22px;">Facebook / Instagram</h2>
            <p class="small">
              Connect a Meta user, map Pages to EN/ES channels (your existing workflow),
              and optionally enable the comment bot.
            </p>

            <div class="hr"></div>

            <div class="card-title">Status</div>
            <% if (meta && meta.connected) { %>
              <p class="small" style="margin-top:8px;">
                Connected as <b><%= meta.fbUserName || "Facebook user" %></b><br/>
                Organization: <b><%= meta.orgName || meta.orgId || "—" %></b>
              </p>
              <div class="btn-row" style="margin-top:12px;">
                <a class="btn primary" href="/meta/select-assets">Manage mapping</a>
                <form method="post" action="/logout" style="display:inline;">
                  <button class="btn" type="submit">Disconnect</button>
                </form>
              </div>
            <% } else { %>
              <p class="small" style="margin-top:8px;">Not connected.</p>
              <div class="btn-row" style="margin-top:12px;">
                <a class="btn primary" href="/meta/connect">Connect Meta</a>
              </div>
            <% } %>

            <div class="hr"></div>
            <div class="card-title">Compliance</div>
            <div class="btn-row" style="margin-top:10px;">
              <a class="btn" href="/privacy">Privacy</a>
              <a class="btn" href="/tos">Terms</a>
              <a class="btn" href="/data-deletion">Data deletion</a>
            </div>
          </div>
        </aside>
      </section>
    </main>

    <%- include('./_partials/footer.ejs') %>
  </div>
</body>
</html>
